APP_NAME="MBG Smart Nutrition"
APP_ENV=local
APP_KEY=base64:uN4hGfSDFgHjKlZxcvBnmQwErTyUiOpAsDfGhJk=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- KONFIGURASI DATABASE UTAMA (XAMPP PORT 3308) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=mbg_smart_nutrition
DB_USERNAME=root
DB_PASSWORD=

# --- FIX ERROR: MODUL DIUBAH KE FILE SELAMA PROSES MIGRASI ---
SESSION_DRIVER=file
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
